PORT=3000
JWT_SECRET=super-secret-test-key

# Controls which login UI and backend flow is active
# Options: email-password | email-otp | email-password-otp | google-oauth
AUTH_TYPE=email-password

# Controls step behaviour in the UI
# Options: single-page | email-first
AUTH_FLOW=single-page

# Controls how the session token is delivered
# Options: cookie | bearer | custom-header
TOKEN_TYPE=cookie

# Only used when TOKEN_TYPE=custom-header
CUSTOM_HEADER_NAME=X-Auth-Token
