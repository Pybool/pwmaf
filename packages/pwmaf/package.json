{
  "name": "qa-pwmaf",
  "version": "1.0.0",
  "description": "Playwright Multi Auth Framework, config based session management for email/password, OTP, OAuth, OIDC, and SAML authentication flows",
  "author": "Emmanuel Eko <eeko.official@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/pybool/pwmaf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pybool/pwmaf.git"
  },
  "bugs": {
    "url": "https://github.com/pybool/pwmaf/issues"
  },
  "keywords": [
    "playwright",
    "authentication",
    "auth",
    "testing",
    "e2e",
    "session",
    "oauth",
    "oidc",
    "saml",
    "otp",
    "2fa",
    "automation",
    "qa",
    "sdet",
    "login",
    "multi-auth",
    "storage-state",
    "global-setup"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/configs/index.mjs",
      "require": "./dist/configs/index.js",
      "types": "./dist/configs/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.mjs",
      "require": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "bin": {
    "pwmaf": "./dist/cli/init.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run typecheck && npm run build",
    "release": "npm run prepublishOnly && npm publish --access=public",
    "release:dry": "npm run prepublishOnly && npm publish --access=public --dry-run"
  },
  "peerDependencies": {
    "@playwright/test": "^1.60.0",
    "ts-node": "^10.9.2"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "dependencies": {
    "axios": "^1.17.0",
    "axios-cookiejar-support": "^7.0.0",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@playwright/test": "^1.61.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^30.4.1",
    "dotenv": "^16.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
